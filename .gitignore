yarn-error.log*
pnpm-debug.log*
dist/
build/

# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.venv/
venv/
pip-wheel-metadata/
*.egg-info/
.eggs/
.tox/

# Testing / coverage
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/

# Logs
logs/
*.log

# Editors / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

